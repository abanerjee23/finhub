OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SUMMARY_MODEL=gpt-4o
SUMMARY_USE_LLM=0
SUMMARY_JUDGE_MODEL=gpt-4o
DISABLE_LLM=0
# CONFIDENCE_REVIEW_THRESHOLD=0.5   # diagnoses below this route to human review
# WORKFLOW_STAGE_LAG_SECONDS=6      # delay per stage in the approve/maintain-mapping pipeline

# Langfuse observability (optional). Either LANGFUSE_HOST or LANGFUSE_BASE_URL works.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Promptfoo cloud (optional). Local eval DB always lives in ./.promptfoo
# PROMPTFOO_API_KEY=          # from https://www.promptfoo.app — enables auth + share
# PROMPTFOO_SHARE=0            # set to 1 to auto-upload eval runs to your cloud org

# Mutable workbench state (SQLite + attachments).
# Local default: data/synthetic (unset FINHUB_DATA_DIR).
# Railway: mount volume at /data, then set:
# FINHUB_DATA_DIR=/data/finhub
# RAILWAY_RUN_UID=0

# Attachment storage: local (default) or s3
# STORAGE_BACKEND=local
# STORAGE_BACKEND=s3
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_PREFIX=attachments/

# API server (local dev defaults; Railway sets PORT automatically)
# API_HOST=127.0.0.1
# API_PORT=8000
# API_RELOAD=1

# Frontend (optional). Leave unset for same-origin /api in dev (Vite proxy) and production.
# VITE_API_BASE=
