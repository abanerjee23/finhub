OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_USE_LLM=0
SUMMARY_JUDGE_MODEL=gpt-4o
DISABLE_LLM=0
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Use either LANGFUSE_HOST or LANGFUSE_BASE_URL (same value)
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Mutable workbench state (SQLite + attachments). On Railway, mount a volume here.
# FINHUB_DATA_DIR=/data/finhub

# Attachment storage: local (default) or s3
# STORAGE_BACKEND=local
# STORAGE_BACKEND=s3
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_PREFIX=attachments/
